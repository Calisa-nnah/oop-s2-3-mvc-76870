@model VgcCollege.Models.AttendanceRecord

@{
    ViewData["Title"] = "Attendance Details";
}

<h1>Attendance Details</h1>

<div>
    <h4>Attendance Record</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Student</dt>
        <dd class="col-sm-10">@Model.CourseEnrolment?.StudentProfile?.Name</dd>

        <dt class="col-sm-2">Course</dt>
        <dd class="col-sm-10">@Model.CourseEnrolment?.Course?.Name</dd>

        <dt class="col-sm-2">Branch</dt>
        <dd class="col-sm-10">@Model.CourseEnrolment?.Course?.Branch?.Name</dd>

        <dt class="col-sm-2">Week Number</dt>
        <dd class="col-sm-10">@Model.WeekNumber</dd>

        <dt class="col-sm-2">Present</dt>
        <dd class="col-sm-10">@Model.Present</dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>