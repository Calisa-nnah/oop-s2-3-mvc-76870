@model IEnumerable<VgcCollege.Models.AttendanceRecord>

@{
    ViewData["Title"] = "Attendance Records";
}

<h1>Attendance Records</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Attendance Record</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Student</th>
            <th>Course</th>
            <th>Branch</th>
            <th>Week Number</th>
            <th>Present</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CourseEnrolment?.StudentProfile?.Name</td>
                <td>@item.CourseEnrolment?.Course?.Name</td>
                <td>@item.CourseEnrolment?.Course?.Branch?.Name</td>
                <td>@item.WeekNumber</td>
                <td>@item.Present</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>