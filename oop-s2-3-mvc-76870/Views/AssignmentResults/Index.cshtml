@model IEnumerable<VgcCollege.Models.AssignmentResult>

<h1>Assignment Results</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Add Result</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Student</th>
            <th>Assignment</th>
            <th>Course</th>
            <th>Branch</th>
            <th>Score</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.StudentProfile?.Name</td>
                <td>@item.Assignment?.Title</td>
                <td>@item.Assignment?.Course?.Name</td>
                <td>@item.Assignment?.Course?.Branch?.Name</td>
                <td>@item.Score</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>