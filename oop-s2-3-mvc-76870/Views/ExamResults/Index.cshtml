@model IEnumerable<VgcCollege.Models.ExamResult>

<h1>Exam Results</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Add Result</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Student</th>
            <th>Exam</th>
            <th>Course</th>
            <th>Score</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.StudentProfile?.Email</td>
                <td>@item.Exam?.Title</td>
                <td>@item.Exam?.Course?.Name</td>
                <td>@item.Score</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>