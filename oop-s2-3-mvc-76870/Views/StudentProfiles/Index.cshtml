@model IEnumerable<VgcCollege.Models.StudentProfile>

@{
    ViewData["Title"] = "Student Profiles";
}

<h1>Student Profiles</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Student Profile</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Student Number</th>
            <th>Course(s)</th>
            <th>Branch(es)</th>
            <th>Linked Login</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Email</td>
                <td>@item.StudentNumber</td>
                <td>
                    @if (item.CourseEnrolments != null && item.CourseEnrolments.Any())
                    {
                @string.Join(", ", item.CourseEnrolments
                                .Where(e => e.Course != null)
                                .Select(e => e.Course!.Name))
                                }
                    else
                    {
                        <span>No enrolments</span>
                    }
                </td>
                <td>
                    @if (item.CourseEnrolments != null && item.CourseEnrolments.Any())
                    {
                @string.Join(", ", item.CourseEnrolments
                                .Where(e => e.Course?.Branch != null)
                                .Select(e => e.Course!.Branch!.Name)
                                .Distinct())
                                }
                    else
                    {
                        <span>No branch</span>
                    }
                </td>
                <td>@item.IdentityUser?.Email</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>