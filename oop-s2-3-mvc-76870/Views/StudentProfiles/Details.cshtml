@model VgcCollege.Models.StudentProfile

@{
    ViewData["Title"] = "Student Profile Details";
}

<h1>Student Profile Details</h1>

<div>
    <h4>Student Profile</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>

        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Email</dd>

        <dt class="col-sm-2">Phone</dt>
        <dd class="col-sm-10">@Model.Phone</dd>

        <dt class="col-sm-2">Address</dt>
        <dd class="col-sm-10">@Model.Address</dd>

        <dt class="col-sm-2">Student Number</dt>
        <dd class="col-sm-10">@Model.StudentNumber</dd>

        <dt class="col-sm-2">Linked Login</dt>
        <dd class="col-sm-10">@Model.IdentityUser?.Email</dd>

        <dt class="col-sm-2">Course(s)</dt>
        <dd class="col-sm-10">
            @if (Model.CourseEnrolments != null && Model.CourseEnrolments.Any())
            {
                <ul>
                    @foreach (var enrolment in Model.CourseEnrolments)
                    {
                        <li>
                            <strong>Course:</strong> @enrolment.Course?.Name <br />
                            <strong>Branch:</strong> @enrolment.Course?.Branch?.Name <br />
                            <strong>Status:</strong> @enrolment.Status <br />
                            <strong>Enrol Date:</strong> @enrolment.EnrolDate.ToShortDateString()
                        </li>
                    }
                </ul>
            }
            else
            {
                <span>No enrolments yet</span>
            }
        </dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>